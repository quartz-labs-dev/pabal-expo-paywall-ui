{
  "name": "pabal-expo-paywall-ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "yarn workspace playground start",
    "dev": "yarn workspace playground start",
    "ios": "yarn workspace playground ios",
    "android": "yarn workspace playground android",
    "web": "yarn workspace playground web",
    "build": "yarn workspace pabal-expo-paywall-ui build",
    "publish:paywall": "yarn workspace pabal-expo-paywall-ui publish --new-version $(node -p \"require('./packages/paywall-ui/package.json').version\") --access public --registry https://registry.npmjs.org",
    "typecheck": "yarn workspaces run typecheck",
    "test": "yarn workspace pabal-expo-paywall-ui test"
  }
}
